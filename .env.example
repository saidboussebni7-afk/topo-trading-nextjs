# انسخ هذا الملف إلى .env.local للتجربة المحلية فقط.
# على Vercel ضع نفس القيم في Settings > Environment Variables.

JSONBIN_ID=PUT_YOUR_NEW_JSONBIN_ID_HERE
JSONBIN_KEY=PUT_YOUR_NEW_JSONBIN_MASTER_KEY_HERE

# شغّل: npm run secure:hash
# ثم انسخ القيم الناتجة هنا وفي Vercel.
ADMIN_PASSWORD_HASH=pbkdf2$310000$REPLACE_SALT$REPLACE_HASH
ADMIN_SESSION_SECRET=REPLACE_WITH_RANDOM_64_HEX_CHARS

# اختياري لإرسال الإشارات إلى تيليجرام من السيرفر فقط.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# true يسمح للمستخدم المرخّص بإرسال إشارات تيليجرام عبر السيرفر.
# ضع false إذا تريد الإرسال من الأدمن فقط.
ALLOW_LICENSE_TELEGRAM_SEND=false
